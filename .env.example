# Copy this file to .env and fill in your token.
# .env is gitignored — never commit it.
#
# Get a Personal Access Token from: https://airtable.com/create/tokens
# Required scope: data.records:write on base appA8bFOOAw72AZ24

AIRTABLE_API_KEY=your_personal_access_token_here

# Congress.gov API key — get one free at: https://api.congress.gov/sign-up/
CONGRESS_API_KEY=your_congress_api_key_here

# Anthropic API key — used by poll_bills.py for Claude Haiku triage
ANTHROPIC_API_KEY=your_anthropic_api_key_here
